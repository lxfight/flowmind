# FlowMind 环境变量配置
# 复制此文件为 .env 并根据需要修改

# ---- 数据库 ----
# PostgreSQL + pgvector（推荐，需要 Docker）
DATABASE_URL=postgresql+asyncpg://flowmind:flowmind_secret@localhost:5432/flowmind

# 本地开发无 Docker 时使用 SQLite（注释上面这行，取消下面这行的注释）
# DATABASE_URL=sqlite+aiosqlite:///./flowmind.db

# ---- JWT 鉴权 ----
# 生产环境务必设置一个随机字符串（可用 openssl rand -hex 32 生成）
# 留空则自动生成随机密钥（每次重启会变化，仅用于开发测试）
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- 应用时区 ----
# LLM 助手感知当前时间所用的时区（服务器运行在 UTC）。
# 决定「今天/明天/本周」等相对时间的换算以及任务截止日期的归属。
APP_TIMEZONE=Asia/Shanghai

# ---- 管理员 ----
# 首次启动时若无用户，自动创建默认超级管理员
# 用户名: admin，密码可通过环境变量指定（不设置则随机生成并打印到控制台）
# FLOWMIND_ADMIN_PASSWORD=your-admin-password

# ---- 应用版本与更新 ----
# 正式部署由 Release 版本控制；本地源码构建保持 local/0.2.0 即可。
# FLOWMIND_VERSION=0.2.0
# updater 拥有独立 Docker 权限，生产环境必须替换为随机值（openssl rand -hex 32）。
# FLOWMIND_UPDATER_TOKEN=replace-with-a-random-secret
# RELEASE_REPOSITORY=lxfight/flowmind
# 可选：只读 GitHub Token，可提高 Release 检查 API 配额。
# GITHUB_TOKEN=github_pat_read_only

# ---- 速率限制 ----
# 登录防暴力破解：每个用户名+IP组合在时间窗口内的最大尝试次数
# RATE_LIMIT_LOGIN_MAX=5
# RATE_LIMIT_WINDOW=60

# ---- LLM 配置（可选） ----
# 默认使用 OpenAI 兼容 API，可以配置为任何兼容的服务
# LLM_API_KEY=sk-your-api-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ---- LLM Embedding 配置（RAG 知识库） ----
# LLM_EMBEDDING_MODEL=text-embedding-3-small
# Embedding 接口可与 chat 分别部署（例如本地向量服务 + 云端 chat）。
# 以下两项留空时，embedding 调用自动回退使用 LLM_API_KEY / LLM_BASE_URL：
# EMBEDDING_API_KEY=sk-your-embedding-key-here
# EMBEDDING_BASE_URL=https://your-embedding-endpoint/v1

# ---- RAG 配置 ----
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64
# TOP_K_RETRIEVAL=5

# ---- 调试模式 ----
# DEBUG=false

# ---- 文件上传 ----
# UPLOAD_DIR=uploads
# AVATAR_MAX_BYTES=2097152
# KNOWLEDGE_MAX_BYTES=26214400
