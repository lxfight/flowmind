# FlowMind 环境变量配置
# 复制此文件为 .env 并根据需要修改

# ---- 数据库 ----
# PostgreSQL + pgvector（推荐，需要 Docker）
DATABASE_URL=postgresql+asyncpg://flowmind:flowmind_secret@localhost:5432/flowmind

# 本地开发无 Docker 时使用 SQLite（注释上面这行，取消下面这行的注释）
# DATABASE_URL=sqlite+aiosqlite:///./flowmind.db

# ---- JWT 鉴权 ----
# 生产环境务必修改为一个随机字符串
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- LLM 配置（可选） ----
# 默认使用 OpenAI 兼容 API，可以配置为任何兼容的服务
# LLM_API_KEY=sk-your-api-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ---- LLM Embedding 配置（RAG 知识库） ----
# LLM_EMBEDDING_MODEL=text-embedding-3-small

# ---- RAG 配置 ----
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64
# TOP_K_RETRIEVAL=5

# ---- 调试模式 ----
# DEBUG=false
